# Werte NUR für den lokalen Prod-Smoke-Test (docker-compose.prod.test.yml).
# Keine echten Geheimnisse - bewusst Test-Passwörter, da nur lokal/intern.

# --- Domains + Origins (Port 8943, da 443 lokal ggf. belegt; self-signed via Caddy tls internal) ---
APP_DOMAIN=bwa.127.0.0.1.nip.io
AUTH_DOMAIN=auth.127.0.0.1.nip.io
APP_ORIGIN=https://bwa.127.0.0.1.nip.io:8943
AUTH_ORIGIN=https://auth.127.0.0.1.nip.io:8943

# --- Datenbank (App) ---
DB_USER=bwa
DB_PASSWORD=local_test_db_pw_8f3a

# --- Keycloak Bootstrap-Admin + eigene DB ---
KC_BOOTSTRAP_ADMIN_USERNAME=admin
KC_BOOTSTRAP_ADMIN_PASSWORD=local_test_kc_admin_pw_2b7c
KC_DB_USERNAME=keycloak
KC_DB_PASSWORD=local_test_kc_db_pw_5e1d

# --- KI (self-hosted Ollama; im Smoke-Test nicht zwingend befragt) ---
BWA_KI_PROVIDER=ollama
OLLAMA_MODEL=llama3.1:8b
