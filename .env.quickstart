# Quickstart-Demo-Konfiguration (NICHT für Produktivbetrieb).
# Feste Demo-Werte: läuft sofort lokal über https://bwa.127.0.0.1.nip.io:8943 (self-signed).
# Demo-Logins: admin/admin (Vollzugriff), leser/leser (nur lesen).

# --- Demo-Realm mit Demo-Logins (statt Prod-Template ohne User) ---
REALM_TEMPLATE=bwa-realm.demo.template.json

# --- Domains + Origins (nip.io zeigt auf 127.0.0.1; Port 8943, da 443 evtl. belegt) ---
APP_DOMAIN=bwa.127.0.0.1.nip.io
AUTH_DOMAIN=auth.127.0.0.1.nip.io
APP_ORIGIN=https://bwa.127.0.0.1.nip.io:8943
AUTH_ORIGIN=https://auth.127.0.0.1.nip.io:8943

# --- Datenbank (App) — Demo-Passwörter ---
DB_USER=bwa
DB_PASSWORD=quickstart_demo_db

# --- Keycloak Bootstrap-Admin + eigene DB — Demo-Passwörter ---
KC_BOOTSTRAP_ADMIN_USERNAME=admin
KC_BOOTSTRAP_ADMIN_PASSWORD=quickstart_demo_kc
KC_DB_USERNAME=keycloak
KC_DB_PASSWORD=quickstart_demo_kcdb

# --- KI (self-hosted Ollama; im Quickstart optional) ---
BWA_KI_PROVIDER=ollama
OLLAMA_MODEL=llama3.1:8b
