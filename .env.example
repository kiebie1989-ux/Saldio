# Vorlage für die Produktions-Umgebungsvariablen (NICHT mit echten Werten committen).
# Kopieren nach .env und Werte setzen — oder ./setup.sh nutzen, das diese Datei erzeugt.

# --- Domains (Reverse-Proxy / TLS; DNS muss auf den Host zeigen) ---
# APP_DOMAIN/AUTH_DOMAIN = nackte Hostnamen (für Caddy-TLS).
APP_DOMAIN=bwa.example.com
AUTH_DOMAIN=auth.example.com
# APP_ORIGIN/AUTH_ORIGIN = volle URLs (Schema, im Sonderfall mit Port). Normalfall: https://<DOMAIN>.
# Treiben Keycloak-Realm-Redirects, OIDC-Issuer, Frontend-Config und CORS — eine Quelle der Wahrheit.
APP_ORIGIN=https://bwa.example.com
AUTH_ORIGIN=https://auth.example.com

# --- Datenbank (App) ---
DB_USER=bwa
DB_PASSWORD=CHANGE_ME_strong

# --- Keycloak Bootstrap-Admin (nur Erststart; legt den ersten Admin in der Admin-Konsole an) ---
KC_BOOTSTRAP_ADMIN_USERNAME=admin
KC_BOOTSTRAP_ADMIN_PASSWORD=CHANGE_ME_strong
# Keycloak-eigene DB
KC_DB_USERNAME=keycloak
KC_DB_PASSWORD=CHANGE_ME_strong

# --- KI (self-hosted Ollama) ---
BWA_KI_PROVIDER=ollama
OLLAMA_MODEL=llama3.1:8b

# --- Backup ---
BACKUP_DIR=/var/backups/bwa
RETENTION_DAYS=30
