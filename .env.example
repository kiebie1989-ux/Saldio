# Vorlage für die Produktions-Umgebungsvariablen (NICHT mit echten Werten committen).
# Kopieren nach .env und Werte setzen. Aktiviert wird das Prod-Profil über SPRING_PROFILES_ACTIVE=prod.

# --- Datenbank (App) ---
DB_URL=jdbc:postgresql://postgres:5432/bwa
DB_USER=bwa
DB_PASSWORD=CHANGE_ME_strong

# --- Keycloak (OIDC Resource Server) ---
KEYCLOAK_ISSUER_URI=https://auth.example.com/realms/bwa
KEYCLOAK_JWK_SET_URI=https://auth.example.com/realms/bwa/protocol/openid-connect/certs

# --- Keycloak Bootstrap-Admin (nur Erststart) ---
KC_BOOTSTRAP_ADMIN_USERNAME=admin
KC_BOOTSTRAP_ADMIN_PASSWORD=CHANGE_ME_strong
# Keycloak-eigene DB
KC_DB_URL=jdbc:postgresql://keycloak-db:5432/keycloak
KC_DB_USERNAME=keycloak
KC_DB_PASSWORD=CHANGE_ME_strong

# --- CORS: erlaubte Frontend-Origins (kommagetrennt) ---
CORS_ALLOWED_ORIGINS=https://bwa.example.com

# --- KI (self-hosted Ollama) ---
BWA_KI_PROVIDER=ollama
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3.1:8b

# --- Spring-Profil ---
SPRING_PROFILES_ACTIVE=prod
